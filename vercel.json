{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/signup",
      "destination": "/signup.html"
    },
    {
      "source": "/profile",
      "destination": "/profile.html"
    },
    {
      "source": "/types",
      "destination": "/types.html"
    },
    {
      "source": "/type",
      "destination": "/type.html"
    },
    {
      "source": "/letters",
      "destination": "/letters.html"
    },
    {
      "source": "/letter",
      "destination": "/letter.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/functions",
      "destination": "/functions.html"
    },
    {
      "source": "/cognitive-functions",
      "destination": "/cognitive-functions.html"
    },
    {
      "source": "/compatibility",
      "destination": "/compatibility.html"
    },
    {
      "source": "/archive",
      "destination": "/archive.html"
    },
    {
      "source": "/forum",
      "destination": "/forum.html"
    },
    {
      "source": "/forum-thread",
      "destination": "/forum-thread.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}